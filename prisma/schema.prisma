generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tutor {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String?
  email     String?

  animais   Animal[]
}

model Animal {s
  id               Int        @id @default(autoincrement())
  nome             String
  especie          String?
  raca             String?
  data_nascimento  DateTime?

  tutor_id Int
  tutor    Tutor @relation(fields: [tutor_id], references: [id])

  consultas Consulta[]
}

model Consulta {
  id             Int      @id @default(autoincrement())
  data_consulta  DateTime
  motivo         String?
  diagnostico    String?
  veterinario    String?

  animal_id Int
  animal    Animal @relation(fields: [animal_id], references: [id])
}